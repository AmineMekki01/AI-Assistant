# ── OpenAI ─────────────────────────────────────────────────────────
# Get yours at https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Models (optional overrides - defaults are fine)
OPENAI_REALTIME_MODEL=gpt-realtime-mini
OPENAI_REALTIME_VOICE=ash
OPENAI_UTILITY_MODEL=gpt-5.4-nano
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Web search (Tavily) ───────────────────────────────────────────
# Get yours at https://tavily.com
TAVILY_API_KEY=tvly-your-api-key-here

# ── Google OAuth (Gmail + Calendar) ───────────────────────────────
# Set up at https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Token cache (leave default unless you have a reason)
GOOGLE_TOKEN_PATH=~/.jarvis/google_token.json

# ── Qdrant (memory + Obsidian RAG) ────────────────────────────────
# `docker run -p 6333:6333 qdrant/qdrant` to run locally.
QDRANT_URL=http://localhost:6333
QDRANT_MEMORY_COLLECTION=long_term_memory
QDRANT_VAULT_COLLECTION=obsidian_vault

# ── Obsidian vault ────────────────────────────────────────────────
# Can also be set via the JARVIS Settings UI; the UI takes precedence.
OBSIDIAN_VAULT_PATH=~/Documents/Obsidian

# ── Identity (optional, single-user default) ──────────────────────
JARVIS_USER_ID=user

# NOTE: Zimbra mail and Apple Calendar are configured entirely
# from the Settings UI (~/.jarvis/settings.json) - no env vars needed.

